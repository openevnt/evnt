{
  "lexicon": 1,
  "id": "directory.evnt.event",
  "defs": {
    "main": {
      "type": "object",
      "properties": {
        "v": {
          "type": "integer",
          "const": 0
        },
        "name": {
          "type": "unknown"
        },
        "label": {
          "type": "unknown"
        },
        "status": {
          "type": "ref",
          "ref": "#eventStatus"
        },
        "venues": {
          "type": "array",
          "items": {
            "type": "union",
            "refs": [
              "#physicalVenue",
              "#onlineVenue",
              "#unknownVenue"
            ]
          }
        },
        "instances": {
          "type": "array",
          "items": {
            "type": "ref",
            "ref": "#eventInstance"
          }
        },
        "components": {
          "type": "array",
          "items": {
            "type": "ref",
            "ref": "#eventComponent"
          }
        }
      },
      "required": [
        "v",
        "name"
      ]
    },
    "PhysicalVenue": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "physical"
        },
        "name": {
          "type": "unknown"
        },
        "address": {
          "type": "ref",
          "ref": "#address"
        },
        "coordinates": {
          "type": "ref",
          "ref": "#coordinates"
        }
      },
      "required": [
        "id",
        "type",
        "name"
      ]
    },
    "Address": {
      "type": "object",
      "properties": {
        "addr": {
          "type": "string"
        },
        "countryCode": {
          "type": "string"
        },
        "postalCode": {
          "type": "string"
        }
      }
    },
    "Coordinates": {
      "type": "object",
      "properties": {
        "lat": {
          "type": "integer"
        },
        "lng": {
          "type": "integer"
        }
      },
      "required": [
        "lat",
        "lng"
      ]
    },
    "OnlineVenue": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "online"
        },
        "name": {
          "type": "unknown"
        },
        "url": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "type",
        "name"
      ]
    },
    "UnknownVenue": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "unknown"
        },
        "name": {
          "type": "unknown"
        }
      },
      "required": [
        "id",
        "type",
        "name"
      ]
    },
    "EventInstance": {
      "type": "object",
      "properties": {
        "venueIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "start": {
          "type": "string"
        },
        "end": {
          "type": "string"
        },
        "status": {
          "type": "ref",
          "ref": "#eventStatus"
        }
      }
    },
    "EventComponent": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "data": {
          "type": "unknown"
        }
      },
      "required": [
        "type",
        "data"
      ]
    },
    "EventStatus": {
      "type": "string",
      "knownValues": [
        "planned",
        "uncertain",
        "postponed",
        "cancelled",
        "suspended"
      ]
    }
  }
}